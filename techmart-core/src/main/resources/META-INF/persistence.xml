<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    
    <persistence-unit name="TechMartPU" transaction-type="JTA">
        <jta-data-source>java:app/jdbc/TechMartDS</jta-data-source>
        
        <!-- Entity classes mapping can be omitted; container scans the classpath -->
        
        <shared-cache-mode>NONE</shared-cache-mode>
        <properties>
            <!-- Database generation strategy - in production, SQL scripts are preferred -->
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
            
            <!-- EclipseLink properties (Default in Payara Server) -->
            <property name="eclipselink.logging.level" value="INFO"/>
            <property name="eclipselink.logging.parameters" value="true"/>
            <property name="eclipselink.target-database" value="PostgreSQL"/>
            <!-- Disable EclipseLink shared cache explicitly via property just in case -->
            <property name="eclipselink.cache.shared.default" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
